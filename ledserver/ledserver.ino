WebSocketsClient webSocket;

void setup() {
  Serial.begin(115200);
  
  // Initialize NeoPixel LED
  pixels.begin();
  pixels.clear();
  pixels.show();
  
  // Connect to WiFi
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("Connected to WiFi");

  // Configure WebSocket client
  webSocket.beginSSL(wsHost, wsPort, wsPath, root_ca);
  webSocket.onEvent(webSocketEvent);
  webSocket.setReconnectInterval(5000);
}

void webSocketEvent(WStype_t type, uint8_t * payload, size_t length) {
  switch(type) {
    case WStype_DISCONNECTED:
      Serial.println("WebSocket disconnected");
      break;
    case WStype_CONNECTED:
      Serial.println("WebSocket connected");
      break;
    case WStype_TEXT:
      handleWebSocketMessage(String((char*)payload));
      break;
  }
}

void handleWebSocketMessage(String data) {
  // Expected format: "RGB:R,G,B" where R,G,B are values 0-255
  if (data.startsWith("RGB:")) {
    String values = data.substring(4);
    int firstComma = values.indexOf(',');
    int secondComma = values.indexOf(',', firstComma + 1);
    
    int red = values.substring(0, firstComma).toInt();
    int green = values.substring(firstComma + 1, secondComma).toInt();
    int blue = values.substring(secondComma + 1).toInt();
    
    // Set RGB LED color using NeoPixel
    pixels.setPixelColor(0, pixels.Color(red, green, blue));
    pixels.show();
    
    Serial.println("Set RGB: " + String(red) + "," + String(green) + "," + String(blue));
  }
}

void loop() {
  webSocket.loop();
}
